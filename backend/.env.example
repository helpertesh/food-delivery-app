# Copy this file to .env and fill in values. Never commit .env.

# --- MySQL (required on Vercel: use a hosted DB, e.g. PlanetScale, Railway, Aiven) ---
# Option A: separate vars (typical)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=food_delivery_db
# DB_PORT=3306
#
# Option B: single URL (Railway / some hosts) — if set, DB_HOST/USER/PASSWORD/NAME are ignored
# DATABASE_URL=mysql://user:password@host:3306/database_name
#
# Most cloud MySQL requires TLS from Vercel — set on Vercel + local if your host says "SSL required":
# DB_SSL=true
# If you get certificate errors with a dev DB only, try (not for untrusted production):
# DB_SSL_REJECT_UNAUTHORIZED=false

# sandbox | production
MPESA_ENV=sandbox

# From Daraja: Dashboard -> My Apps -> your app (Consumer Key / Consumer Secret)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Sandbox: shortcode 174379 + public sandbox passkey (see Daraja Lipa na M-Pesa docs)
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# REQUIRED for real STK (not simulation): HTTPS URL on the public internet.
# Safaricom POSTs payment results here. localhost will NOT work.
#
# Local machine steps:
#   1. ngrok authtoken (once): sign up at https://dashboard.ngrok.com then:
#        ngrok config add-authtoken YOUR_TOKEN
#      If `ngrok` is not on PATH, use full path to ngrok.exe (see below).
#   2. Put a CURRENT ngrok.exe in backend/tools/ngrok-win/ (download zip from https://ngrok.com/download ).
#      winget's Ngrok is often old (3.3.x) and may fail with ERR_NGROK_121 — use the zip from ngrok.com.
#   3. With node server.js running on 3000, from the backend folder run:
#        powershell -ExecutionPolicy Bypass -File .\scripts\start-ngrok.ps1
#      Or run ngrok.exe manually:  ngrok.exe http 3000
#   4. Fallback WinGet path (not on PATH): 
#        & "$env:LOCALAPPDATA\Microsoft\WinGet\Packages\Ngrok.Ngrok_Microsoft.Winget.Source_8wekyb3d8bbwe\ngrok.exe" http 3000
#   5. Copy the "Forwarding" https URL (e.g. https://a1b2-3c4d.ngrok-free.app)
#   6. Paste below (replace the https://... part with YOUR ngrok https URL, no trailing slash):
MPESA_CALLBACK_URL=
#
# Example after ngrok gives you https://abc123.ngrok-free.app :
# MPESA_CALLBACK_URL=https://abc123.ngrok-free.app/api/payment/mpesa/callback
#
# If Daraja has "URL Management", register the same callback URL there if required.

# CustomerPayBillOnline (default) or CustomerBuyGoodsOnline (Till)
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# MPESA_PARTY_B=

# true = fake STK success after ~5s (no callback, no ngrok). Use while setting up ngrok.
MPESA_USE_SIMULATION=false

# --- Vercel ---
# Deploy the repo root. Build copies frontend/ -> public/; Express entry is server.js at the repo root.
# Dashboard → Environment Variables: add DB_* and MPESA_* (and any other secrets from this file).
# MPESA_CALLBACK_URL: https://YOUR-PROJECT.vercel.app/api/payment/mpesa/callback
# Local MySQL: set DB_PASSWORD (and other DB_*) in backend/.env — credentials are no longer hardcoded in code.
# Uploaded images use /tmp on Vercel and do not persist; prefer image URLs or cloud storage.
# M-Pesa status is in-memory per serverless instance; use MPESA_USE_SIMULATION or external state for production.
