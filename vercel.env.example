# Fill in values, then Vercel → Settings → Environment Variables → Import .env
# Do not commit a filled copy.

# ========== Database (pick ONE backend) ==========
#
# --- A) Supabase / PostgreSQL (recommended if you use Supabase) ---
# Vercel often provides one or more of these after linking Supabase:
#   POSTGRES_URL, POSTGRES_URL_NON_POOLING, POSTGRES_PRISMA_URL
# Or set DATABASE_URL to your Supabase connection string (postgresql://...).
# First valid postgres:// URL wins. Then run backend/schema.supabase.sql in Supabase SQL Editor.
#
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-....pooler.supabase.com:6543/postgres
#
# If you still see "self-signed certificate in certificate chain", set:
# PGSSLMODE=no-verify
# Optional: DB_SSL=false only if you must disable TLS (not typical on Supabase).
#
# --- B) MySQL (hosted only; never localhost on Vercel) ---
# DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE
# Or separate:
# DB_HOST=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# DB_PORT=3306
# DB_SSL=true

# --- M-Pesa Daraja ---
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://food-delivery-app.vercel.app/api/payment/mpesa/callback
MPESA_USE_SIMULATION=false
